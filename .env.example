# ==========================================
# 环境变量配置示例
# 复制本文件为 .env 并填入真实值
# ==========================================

# DeepSeek API配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 本地资料库路径
# Windows示例: C:\company_docs
# macOS/Linux示例: /Users/username/company_docs
REPOSITORY_ROOT_PATH=/path/to/your/company/docs

# 项目数据输出目录
OUTPUT_DIR=./output

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# 是否启用调试模式
DEBUG=false

# 数据库类型
DB_TYPE=sqlite
DB_PATH=./data/bidding.db
